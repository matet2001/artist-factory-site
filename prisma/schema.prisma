generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  password           String
  phone              String?
  bandName           String?
  emailVerified      DateTime?
  isAdmin            Boolean             @default(false)
  lastEmailSent      DateTime?
  emailSentCount     Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  verificationTokens VerificationToken[]

  // Migration tracking fields
  isOldUser                 Boolean   @default(false) // Migrated from old system
  lastVerificationEmailSent DateTime? // For rate limiting resends

  bookings Booking[]

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, token])
  @@index([email])
}

model Room {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  size        Int
  price       Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("rooms")
}

enum BookingStatus {
  PLANNED
  UNVERIFIED
  VERIFIED
  CANCELLED
}

model Booking {
  id     String        @id @default(cuid())
  date   DateTime      @db.Date
  time   Int // hour (9-22)
  status BookingStatus @default(UNVERIFIED)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  note String? // Admin notes for the booking

  verificationToken String?
  verifiedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, time, roomId])
  @@index([date, roomId])
  @@index([userId])
  @@index([verificationToken])
  @@map("bookings")
}

model BookingVerification {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  userId    String
  date      DateTime @db.Date
  bookings  Json // Store array of {roomId, time}
  status    String   @default("pending") // "pending" | "verified" | "expired"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("booking_verifications")
}
